# ── LLM APIs ───────────────────────────────────────────────
OPENAI_API_KEY=sk-...
COHERE_API_KEY=...

# ── Vector Database (Qdrant) ───────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                          # Leave blank for local Docker instance
QDRANT_COLLECTION_NAME=financial_rag

# ── Observability ──────────────────────────────────────────
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com
LANGSMITH_API_KEY=lsv2_...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=financial-rag

# ── SEC EDGAR ──────────────────────────────────────────────
SEC_USER_AGENT=YourName YourEmail@example.com   # Required by SEC EDGAR API ToS

# ── Pipeline Config ────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RETRIEVAL=20
TOP_K_RERANK=5
EMBEDDING_MODEL=text-embedding-3-large
LLM_MODEL=gpt-4o
