# ── LLM (Groq API) ─────────────────────────────────────────
# Get a free key: https://console.groq.com/keys
GROQ_API_KEY=

# ── Vector Database (Qdrant) ───────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                          # Leave blank for local Docker instance
QDRANT_COLLECTION_NAME=financial_rag

# ── SEC EDGAR ──────────────────────────────────────────────
SEC_USER_AGENT=YourName YourEmail@example.com   # Required by SEC EDGAR API ToS

# ── Pipeline Config ────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RETRIEVAL=20
TOP_K_RERANK=5
EMBEDDING_MODEL=BAAI/bge-m3             # Local sentence-transformers model
LLM_MODEL=llama-3.3-70b-versatile       # Groq-hosted model id
